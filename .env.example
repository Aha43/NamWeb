# Defaults below target the local Supabase stack run from THIS repo (`npm run db:start`;
# needs Docker Desktop). Config + migrations live in `supabase/` here — the single source of
# truth since NamDesktop was parked. For a hosted backend, swap these for your project's URL
# and publishable key.

VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

# Which workspace row to sync against. `default` is the app's normal row; `dev` was the
# dev-mode desktop's row (kept for reading old dev data).
VITE_WORKSPACE_NAME=default

# Cloudflare Turnstile bot protection on sign-up (production). Leave unset for local
# dev — the widget/check is then inert. Set the matching secret in the hosted
# Supabase project's auth captcha config so signUp tokens are verified server-side.
# VITE_TURNSTILE_SITE_KEY=0x4AAAAAAA...

# --- Remote MCP server (read-only, OAuth-gated; `npm run mcp`) ---------------
# Only needed to run mcp/server.ts. Reuses the VITE_SUPABASE_* and
# VITE_WORKSPACE_NAME values above. See mcp/README.md.
NAM_MCP_PORT=3333
# Public origin the OAuth Authorization Server advertises in its metadata. Set this
# to your tunnel's https origin when connecting ChatGPT/Claude web; defaults to
# http://127.0.0.1:<port> for local use.
# NAM_MCP_ISSUER_URL=https://your-tunnel.example

# Persist OAuth state (registered clients + issued tokens) to an MCP-owned `mcp`
# Postgres schema so connectors don't re-authorize on every server restart. Points
# at the same Supabase Postgres; used for the AS's own bookkeeping (service-level,
# off PostgREST), not the user-RLS data plane. Unset = in-memory (drops on restart).
# Local stack default shown below.
# NAM_MCP_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Dev/Inspector escape hatch: NAM_MCP_DEV_NOAUTH=1 disables OAuth and serves one
# shared session signed in with the credentials below (the P0 path). Local only —
# never deploy this. Leave unset for normal OAuth mode. Never commit real credentials.
# NAM_MCP_DEV_NOAUTH=1
# NAM_MCP_EMAIL=you@example.com
# NAM_MCP_PASSWORD=your-password
