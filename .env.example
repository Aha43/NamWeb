# NamWeb connects to the same Supabase project as NamDesktop cloud sync.
# Defaults below target the local Supabase stack run from NamDesktop (`make supabase-start`).
# For a hosted backend, swap these for your project's URL and publishable key.

VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

# Which workspace row to sync against — must match the name NamDesktop syncs under.
# Normal-mode desktop uses `default` (the default here); dev-mode desktop uses `dev`,
# so set this to `dev` when testing against a dev-mode desktop's cloud data.
VITE_WORKSPACE_NAME=default

# --- Remote MCP server (P0 read-only prototype; `npm run mcp`) ---------------
# Only needed to run mcp/server.ts. P0 has no OAuth, so the server signs in with
# a Supabase user's credentials (the user that owns the workspace row above).
# Reuses the VITE_SUPABASE_* and VITE_WORKSPACE_NAME values above. Never commit
# real credentials. See mcp/README.md.
NAM_MCP_EMAIL=you@example.com
NAM_MCP_PASSWORD=your-password
NAM_MCP_PORT=3333
